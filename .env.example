# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@your-project.neon.tech/neondb?sslmode=require"

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Cron secret (any random string — set the same value in Vercel env vars)
CRON_SECRET=""

# Only needed locally to trigger the cron reminder check in dev
NEXT_PUBLIC_DEV_CRON_SECRET=""
